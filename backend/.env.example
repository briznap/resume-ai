# ── AI ──
# Anthropic API key — never expose to frontend, never log
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Email (magic link delivery) ──
RESEND_API_KEY=re_...

# ── Auth ──
# Comma-separated list of email addresses allowed to authenticate
ALLOWED_EMAILS=brad@naplab.org,recruiter@example.com

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace_with_64_char_hex_string
HMAC_SECRET=replace_with_64_char_hex_string

# ── CORS ──
# Exact origin of the frontend — no trailing slash, no wildcards
FRONTEND_ORIGIN=https://resume.naplab.org

# ── Resume data ──
# Path to resume.json — in Docker this is /app/resume.json (mounted as volume)
# Locally: ../resume.json (relative to backend/ directory)
RESUME_PATH=/app/resume.json

# ── Runtime ──
ENVIRONMENT=production
# ENVIRONMENT=development
