# ── AI ──
# Anthropic API key — never expose to frontend, never log
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Email (OPTIONAL — not used by the current auth flow) ──
# Access is granted immediately on an allowlist match (no email is sent), so
# these are not required and the app starts/authenticates fine without them.
# They are only needed if you re-enable the magic-link email flow.
# RESEND_API_KEY=re_...
# FROM_EMAIL=Brad Belnap <noreply@naplab.org>

# ── Auth (Phase 2) ──
# Comma-separated allowlist. Two entry types, both case-insensitive:
#   exact address:    brad@naplab.org
#   domain wildcard:  @example.com   (matches any address at that domain)
# Allowlist membership is never revealed to clients (enumeration protection).
ALLOWED_EMAILS=brad@naplab.org,@trustedpartner.com

# 32-byte hex secrets. Generate each with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace_with_64_char_hex_string   # signs the session cookie
HMAC_SECRET=replace_with_64_char_hex_string      # hashes magic-link tokens

# ── Admin ──
# Secret for GET /api/admin/logs (sent as the X-Admin-Secret header).
# If unset, the endpoint is disabled (always 401). Generate like the others:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=replace_with_64_char_hex_string

# ── Logging ──
# Structured JSON event log (one JSON object per line; 10 MB x 5 rotation).
# In Docker this is /app/logs/resume-ai.log (../logs mounted as a volume).
# Locally: ../logs/resume-ai.log (relative to backend/). If the path isn't
# writable, events fall back to the console log instead of crashing.
LOG_PATH=/app/logs/resume-ai.log

# ── CORS ──
# Exact origin of the frontend — no trailing slash, no wildcards
FRONTEND_ORIGIN=https://resume.naplab.org

# ── Resume data ──
# Path to resume.json — in Docker this is /app/resume.json (mounted as volume)
# Locally: ../resume.json (relative to backend/ directory)
RESUME_PATH=/app/resume.json

# ── Agent context (optional) ──
# Free-form extra context for the AI agent, appended after the resume data.
# Defaults to /app/agent-context.md in Docker (mounted as a volume); use
# ../agent-context.md for local dev (relative to backend/). If the file is
# missing the agent still works with resume data only.
AGENT_CONTEXT_PATH=/app/agent-context.md

# ── Runtime ──
ENVIRONMENT=production
# ENVIRONMENT=development
